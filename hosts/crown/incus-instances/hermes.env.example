# Copy the shape of this file to:
# /mnt/crownstore/Sync/app-config/hermes/hermes.env
#
# These are dummy placeholders only. Do not put real secrets in this repo.

# LLM provider credentials. Keep one or more real provider keys here.
# The default model is declared in containers/hermes.nix.
OPENROUTER_API_KEY=sk-or-v1-placeholder
# OPENAI_API_KEY=sk-placeholder
# ANTHROPIC_API_KEY=sk-ant-placeholder
# GOOGLE_API_KEY=AIza-placeholder

# OpenAI-compatible Hermes API at https://api.hermes.r6t.io.
# API_SERVER_ENABLED/HOST/PORT are already set in containers/hermes.nix;
# API_SERVER_KEY is required and must be a strong bearer token.
API_SERVER_KEY=replace-with-openssl-rand-hex-32

# Dashboard auth. Hermes requires an auth provider when the dashboard binds
# 0.0.0.0, even when access is restricted by tailnet/network policy.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=scrypt$16384$8$1$placeholder-salt$placeholder-hash
HERMES_DASHBOARD_BASIC_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Plaintext password fallback. Prefer PASSWORD_HASH above and leave this unset.
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=replace-with-temporary-password

# Self-hosted OIDC alternative. Leave unset when using basic auth.
# Requires a public OIDC client with PKCE and no client secret.
# HERMES_DASHBOARD_OIDC_ISSUER=https://id.example.com/application/o/hermes/
# HERMES_DASHBOARD_OIDC_CLIENT_ID=hermes-dashboard
# HERMES_DASHBOARD_OIDC_SCOPES=openid profile email

# Signal. SIGNAL_HTTP_URL is already set in containers/hermes.nix for the local
# signal-cli daemon. Use E.164 phone numbers for account and DM allowlist.
SIGNAL_ACCOUNT=+15555550100
SIGNAL_ALLOWED_USERS=+15555550101,+15555550102

# Optional Signal group support. Groups are disabled unless this is set.
# Use comma-separated signal-cli group IDs, or * to allow every group.
# SIGNAL_GROUP_ALLOWED_USERS=group-id-placeholder
SIGNAL_REQUIRE_MENTION=true
SIGNAL_REACTIONS=true
