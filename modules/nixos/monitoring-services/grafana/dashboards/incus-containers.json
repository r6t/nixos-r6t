{
  "title": "r6 Incus Containers",
  "uid": "r6-incus-containers",
  "tags": ["nixos", "incus"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(incus_uptime_seconds, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": { "text": "crown:9101", "value": "crown:9101" }
      },
      {
        "name": "container",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(incus_uptime_seconds{instance=~\"$host\"}, name)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Container Fleet Overview — $host",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Containers",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(incus_uptime_seconds{instance=~\"$host\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#08bdba", "value": null }]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage per Container",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 1, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_cpu_seconds_total{instance=~\"$host\", name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory Usage (RSS)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "incus_memory_RSS_bytes{instance=~\"$host\", name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Container Events & Logs",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "State Changes & Container Logs",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "{source=\"incus\", host=~\"$container\"} |~ \"state|starting|stopped|error\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
