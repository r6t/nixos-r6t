{
  "title": "r6 Incus Containers",
  "uid": "r6-incus-containers",
  "tags": ["nixos", "incus"],
  "timezone": "browser",
  "schemaVersion": 37,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(incus_cpu_seconds_total{job=\"incus\"}, name)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "options": [],
        "definition": "label_values(incus_cpu_seconds_total{job=\"incus\"}, name)"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running Containers",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 3 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(incus_procs_total{job=\"incus\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Memory Used",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 3 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(incus_memory_MemTotal_bytes{job=\"incus\"} - incus_memory_MemAvailable_bytes{job=\"incus\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Process Count",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 3 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(incus_procs_total{job=\"incus\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Network RX Rate",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 3 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(incus_network_receive_bytes_total{job=\"incus\",device=\"eth0\"}[$__rate_interval])) * 8",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Per-Container Resources",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage Rate",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_cpu_seconds_total{job=\"incus\",name=~\"$container\",mode!=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "incus_memory_MemTotal_bytes{job=\"incus\",name=~\"$container\"} - incus_memory_MemAvailable_bytes{job=\"incus\",name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network RX Rate",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(incus_network_receive_bytes_total{job=\"incus\",name=~\"$container\",device=\"eth0\"}[$__rate_interval]) * 8",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Network TX Rate",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(incus_network_transmit_bytes_total{job=\"incus\",name=~\"$container\",device=\"eth0\"}[$__rate_interval]) * 8",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Disk Read Rate",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_disk_read_bytes_total{job=\"incus\",name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk Write Rate",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_disk_written_bytes_total{job=\"incus\",name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Process Count",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "incus_procs_total{job=\"incus\",name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Filesystem Usage %",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (incus_filesystem_avail_bytes{job=\"incus\",name=~\"$container\",fstype!=\"\"} / incus_filesystem_size_bytes{job=\"incus\",name=~\"$container\",fstype!=\"\"} * 100)",
          "legendFormat": "{{name}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    }
  ]
}
