{
  "title": "r6 Incus Containers",
  "uid": "r6-incus-containers",
  "tags": ["nixos", "incus"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(incus_uptime_seconds, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "container",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(incus_uptime_seconds{instance=~\"$host\"}, name)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Container Fleet Status — $host",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Running Containers",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(incus_uptime_seconds{instance=\"$host\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#42be65" } }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Container Uptime",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 1, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "incus_uptime_seconds{instance=\"$host\", name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter" }
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Compute Resources",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage (Cores)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_cpu_seconds_total{instance=\"$host\", name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory Usage (RSS)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "incus_memory_RSS_bytes{instance=\"$host\", name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Network & I/O",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Network Throughput",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_network_receive_bytes_total{instance=\"$host\", name=~\"$container\"}[$__rate_interval])) * 8",
          "legendFormat": "{{name}} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(incus_network_transmit_bytes_total{instance=\"$host\", name=~\"$container\"}[$__rate_interval])) * -8",
          "legendFormat": "{{name}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Disk I/O Bandwidth",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(incus_disk_read_bytes_total{instance=\"$host\", name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "{{name}} Read",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(incus_disk_write_bytes_total{instance=\"$host\", name=~\"$container\"}[$__rate_interval])) * -1",
          "legendFormat": "{{name}} Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Container Logs",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent Container Logs",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 12 },
      "targets": [
        {
          "expr": "{source=\"incus\", host=~\"$container\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
