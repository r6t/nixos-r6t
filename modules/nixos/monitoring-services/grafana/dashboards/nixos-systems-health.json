{
  "title": "r6 Nix Systems Health",
  "uid": "r6-nix-full",
  "tags": ["nixos", "systems"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": ".*" }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "System Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Uptime",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=~\"$host\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#08bdba", "value": null }]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "CPU Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{instance=~\"$host\",mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ff7eb6", "value": 70 },
              { "color": "#ee5396", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Memory Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes{instance=~\"$host\"} - node_memory_MemAvailable_bytes{instance=~\"$host\"}) / node_memory_MemTotal_bytes{instance=~\"$host\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ff7eb6", "value": 70 },
              { "color": "#ee5396", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Root FS Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{instance=~\"$host\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=~\"$host\",mountpoint=\"/\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ff7eb6", "value": 80 },
              { "color": "#ee5396", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "System Load (5m)",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "node_load5{instance=~\"$host\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Avg Temp",
      "datasource": "Prometheus",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "avg by (instance) (node_hwmon_temp_celsius{instance=~\"$host\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#82cfff", "value": null },
              { "color": "#ff7eb6", "value": 65 },
              { "color": "#ee5396", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Hardware Health & Errors",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Correctable Memory Errors (EDAC)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (instance) (node_edac_correctable_errors_total{instance=~\"$host\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars" } }
      }
    },
    {
      "id": 52,
      "type": "stat",
      "title": "System Entropy",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "node_entropy_available_bits{instance=~\"$host\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bits",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 256 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Storage & ZFS Details",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "ZFS Pool Capacity (%)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_zfs_zpool_capacity_ratio{instance=~\"$host\"} * 100",
          "legendFormat": "{{instance}}: {{zpool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "ZFS ARC Size",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_zfs_arc_size{instance=~\"$host\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decbytes", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Network & Tailscale Details",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Physical Interface Throughput",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, device) (rate(node_network_receive_bytes_total{instance=~\"$host\",device!~\"lo|veth.*|br.*|incus.*|tailscale.*\"}[$__rate_interval])) * 8",
          "legendFormat": "{{instance}} {{device}} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (instance, device) (rate(node_network_transmit_bytes_total{instance=~\"$host\",device!~\"lo|veth.*|br.*|incus.*|tailscale.*\"}[$__rate_interval])) * -8",
          "legendFormat": "{{instance}} {{device}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Tailscale Throughput",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_network_receive_bytes_total{instance=~\"$host\",device=\"tailscale0\"}[$__rate_interval])) * 8",
          "legendFormat": "{{instance}} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(node_network_transmit_bytes_total{instance=~\"$host\",device=\"tailscale0\"}[$__rate_interval])) * -8",
          "legendFormat": "{{instance}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Thermal Status",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Hardware Temperatures",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "node_hwmon_temp_celsius{instance=~\"$host\"}",
          "legendFormat": "{{instance}} {{sensor}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "showPoints": "never" } }
      }
    }
  ]
}
