{
  "title": "r6 Nix Systems Health",
  "uid": "r6-nix-full",
  "tags": ["nixos", "systems"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(node_uname_info{job=\"r6-nix-systems\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": ".*" }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "System Load & Status",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Load (5m)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_load5{instance=~\"$host\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{instance=~\"$host\",mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Memory & Storage",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes{instance=~\"$host\"} - node_memory_MemAvailable_bytes{instance=~\"$host\"}) / node_memory_MemTotal_bytes{instance=~\"$host\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Root Filesystem Usage (%)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{instance=~\"$host\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=~\"$host\",mountpoint=\"/\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Network Traffic",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Traffic per Host",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_network_receive_bytes_total{instance=~\"$host\",device!~\"lo|veth.*|br.*|incus.*\"}[$__rate_interval])) * 8",
          "legendFormat": "{{instance}} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(node_network_transmit_bytes_total{instance=~\"$host\",device!~\"lo|veth.*|br.*|incus.*\"}[$__rate_interval])) * -8",
          "legendFormat": "{{instance}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        }
      }
    }
  ]
}
