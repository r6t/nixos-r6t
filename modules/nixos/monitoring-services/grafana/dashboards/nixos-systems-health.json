{
  "title": "r6 Nix Systems Health",
  "uid": "r6-nix-full",
  "tags": ["nixos", "systems"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 6,
  "editable": true,
  "refresh": "30s",
  "links": [
    {
      "title": "Incus Containers",
      "url": "/d/r6-incus-containers",
      "type": "link",
      "icon": "dashboard"
    },
    {
      "title": "Router Health",
      "url": "/d/r6-router-health",
      "type": "link",
      "icon": "dashboard"
    },
    {
      "title": "Log Explorer",
      "url": "/d/r6-log-explorer",
      "type": "link",
      "icon": "dashboard"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Prometheus",
        "query": "query_result(node_uname_info)",
        "regex": "/instance=\"(?<value>[^\"]+)\".*nodename=\"(?<text>[^\"]+)\"/",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": ".*" }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet Health Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 100,
      "type": "stat",
      "title": "Failed Systemd Units",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum by (nodename) (node_systemd_unit_state{instance=~\"$host\", state=\"failed\"}) or on() vector(0)",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ee5396", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Uptime",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=~\"$host\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#08bdba", "value": null }]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 12,
      "type": "gauge",
      "title": "CPU Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "100 - (avg by (instance, nodename) (rate(node_cpu_seconds_total{instance=~\"$host\",mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ff7eb6", "value": 70 },
              { "color": "#ee5396", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "gauge",
      "title": "Memory Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes{instance=~\"$host\"} - node_memory_MemAvailable_bytes{instance=~\"$host\"}) / node_memory_MemTotal_bytes{instance=~\"$host\"}) * 100",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ff7eb6", "value": 70 },
              { "color": "#ee5396", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Resource Performance & Saturation",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 101,
      "type": "timeseries",
      "title": "Disk Latency (Await)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "(rate(node_disk_read_time_seconds_total{instance=~\"$host\"}[5m]) + rate(node_disk_write_time_seconds_total{instance=~\"$host\"}[5m])) / (rate(node_disk_reads_completed_total{instance=~\"$host\"}[5m]) + rate(node_disk_writes_completed_total{instance=~\"$host\"}[5m]))",
          "legendFormat": "{{nodename}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 102,
      "type": "timeseries",
      "title": "TCP Retransmissions",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(node_netstat_Tcp_RetransSegs{instance=~\"$host\"}[5m])",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Storage & ZFS Details",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "ZFS Pool Capacity (%)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_zfs_zpool_capacity_ratio{instance=~\"$host\"} * 100",
          "legendFormat": "{{nodename}}: {{zpool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "ZFS ARC Size",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_zfs_arc_size{instance=~\"$host\"}",
          "legendFormat": "{{nodename}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decbytes", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Network & Connectivity",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Physical Interface Throughput",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, nodename, device) (rate(node_network_receive_bytes_total{instance=~\"$host\",device!~\"lo|veth.*|br.*|incus.*|tailscale.*\"}[$__rate_interval])) * 8",
          "legendFormat": "{{nodename}} {{device}} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (instance, nodename, device) (rate(node_network_transmit_bytes_total{instance=~\"$host\",device!~\"lo|veth.*|br.*|incus.*|tailscale.*\"}[$__rate_interval])) * -8",
          "legendFormat": "{{nodename}} {{device}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Tailscale Throughput",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, nodename) (rate(node_network_receive_bytes_total{instance=~\"$host\",device=\"tailscale0\"}[$__rate_interval])) * 8",
          "legendFormat": "{{nodename}} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (instance, nodename) (rate(node_network_transmit_bytes_total{instance=~\"$host\",device=\"tailscale0\"}[$__rate_interval])) * -8",
          "legendFormat": "{{nodename}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 60,
      "type": "row",
      "title": "Fleet DNS Activity",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 }
    },
    {
      "id": 61,
      "type": "timeseries",
      "title": "DNS Query Volume by Host",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({unit=\"dnsmasq.service\"} | regexp \"query\\\\[.*\\\\]\" [$__interval]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "qps", "custom": { "fillOpacity": 10 } }
      }
    }
  ]
}
