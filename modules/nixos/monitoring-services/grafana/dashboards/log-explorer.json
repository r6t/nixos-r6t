{
  "title": "r6 Log Explorer",
  "uid": "r6-log-explorer",
  "tags": ["nixos", "logs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "editable": true,
  "refresh": "30s",
  "links": [
    {
      "title": "Systems Health",
      "url": "/d/r6-nix-full",
      "type": "link",
      "icon": "dashboard"
    },
    {
      "title": "Incus Containers",
      "url": "/d/r6-incus-containers",
      "type": "link",
      "icon": "dashboard"
    },
    {
      "title": "Router Health",
      "url": "/d/r6-router-health",
      "type": "link",
      "icon": "dashboard"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(host)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {}
      },
      {
        "name": "unit",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({host=~\"$host\"}, unit)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {}
      },
      {
        "name": "source",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({host=~\"$host\", unit=~\"$unit\"}, source)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {}
      },
      {
        "name": "severity",
        "type": "custom",
        "query": "0,1,2,3,4,5,6,7",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "options": [
          { "text": "0 - Emergency", "value": "0" },
          { "text": "1 - Alert", "value": "1" },
          { "text": "2 - Critical", "value": "2" },
          { "text": "3 - Error", "value": "3" },
          { "text": "4 - Warning", "value": "4" },
          { "text": "5 - Notice", "value": "5" },
          { "text": "6 - Info", "value": "6" },
          { "text": "7 - Debug", "value": "7" }
        ],
        "current": {}
      },
      {
        "name": "search",
        "type": "textbox",
        "defaultValue": "",
        "label": "Search"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 10,
      "type": "row",
      "title": "Fleet Logs Pulse",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Critical/Errors",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\", severity=~\"[0-3]\"} [$__range])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ee5396", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Warnings",
      "datasource": "Loki",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\", severity=\"4\"} [$__range])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#ff7eb6" } }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Active Units",
      "datasource": "Loki",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "count(sum by (unit) (count_over_time({host=~\"$host\"} [$__range]))) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#08bdba" } }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Critical Events (Filtered View)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "type": "logs",
      "title": "System Failures & Crashes",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "{host=~\"$host\"} |~ \"(?i)out of memory|oom-kill|segfault|failed with result|core dumped|panic|kernel oops\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Log Rate & Anomaly Detection",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Volume by Host",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({host=~\"$host\", unit=~\"$unit\", source=~\"$source\", severity=~\"$severity\"} |~ \"$search\" [$__interval]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Live Stream",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Filtered Log Stream",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 20 },
      "targets": [
        {
          "expr": "{host=~\"$host\", unit=~\"$unit\", source=~\"$source\", severity=~\"$severity\"} |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
