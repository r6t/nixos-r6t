{
  "title": "r6 Log Explorer",
  "uid": "r6-log-explorer",
  "tags": ["nixos", "logs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(host)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      },
      {
        "name": "unit",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({host=~\"$host\"}, unit)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Volume Over Time",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({host=~\"$host\", unit=~\"$unit\"}[$__interval]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Log Stream",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 16 },
      "targets": [
        {
          "expr": "{host=~\"$host\", unit=~\"$unit\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
