{
  "title": "r6 Router & Exit Nodes",
  "uid": "r6-router-exit-nodes",
  "tags": ["nixos", "network"],
  "timezone": "browser",
  "schemaVersion": 37,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "exit_node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(wg_peer_transfer_rx_bytes, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "options": []
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Router Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{instance=\"192.168.6.1:9000\",mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"192.168.6.1:9000\"} - node_memory_MemAvailable_bytes{instance=\"192.168.6.1:9000\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"192.168.6.1:9000\"}",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network Throughput — WAN",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"192.168.6.1:9000\",device=\"enp101s0\"}[$__rate_interval]) * 8",
          "legendFormat": "Download",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"192.168.6.1:9000\",device=\"enp101s0\"}[$__rate_interval]) * 8",
          "legendFormat": "Upload",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Network Throughput — LAN",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"192.168.6.1:9000\",device=\"enp100s0\"}[$__rate_interval]) * 8",
          "legendFormat": "Download",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"192.168.6.1:9000\",device=\"enp100s0\"}[$__rate_interval]) * 8",
          "legendFormat": "Upload",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Conntrack Usage",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_nf_conntrack_entries{instance=\"192.168.6.1:9000\"}",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "expr": "node_nf_conntrack_entries_limit{instance=\"192.168.6.1:9000\"}",
          "legendFormat": "Limit",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Uptime",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 3 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=\"192.168.6.1:9000\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "WireGuard Exit Nodes",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Peer Transfer Rate — RX",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(wg_peer_transfer_rx_bytes{instance=~\"$exit_node\"}[$__rate_interval]) * 8",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Peer Transfer Rate — TX",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(wg_peer_transfer_tx_bytes{instance=~\"$exit_node\"}[$__rate_interval]) * 8",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Last Handshake Age",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "time() - wg_peer_last_handshake_seconds{instance=~\"$exit_node\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "area"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "descending" }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Cumulative Transfer",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 3 },
      "targets": [
        {
          "expr": "wg_peer_transfer_rx_bytes{instance=~\"$exit_node\"}",
          "legendFormat": "{{instance}} RX",
          "refId": "A"
        },
        {
          "expr": "wg_peer_transfer_tx_bytes{instance=~\"$exit_node\"}",
          "legendFormat": "{{instance}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      }
    }
  ]
}
