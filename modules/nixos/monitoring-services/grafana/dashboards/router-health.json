{
  "title": "r6 Router Health",
  "uid": "r6-router-health",
  "tags": ["nixos", "network", "router"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "editable": true,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "router",
        "type": "constant",
        "query": "192.168.6.1:9000",
        "hide": 2
      },
      {
        "name": "exit_node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(wg_peer_transfer_rx_bytes, instance)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "options": []
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Core System Status",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Service Status",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 3 },
      "targets": [
        {
          "expr": "node_systemd_unit_state{instance=\"$router\",name=\"dnsmasq.service\",state=\"active\"}",
          "legendFormat": "dnsmasq",
          "refId": "A"
        },
        {
          "expr": "node_systemd_unit_state{instance=\"$router\",name=\"nextdns.service\",state=\"active\"}",
          "legendFormat": "NextDNS",
          "refId": "B"
        },
        {
          "expr": "node_systemd_unit_state{instance=\"$router\",name=\"cake-qos-egress.service\",state=\"active\"}",
          "legendFormat": "CAKE Egress",
          "refId": "C"
        },
        {
          "expr": "node_systemd_unit_state{instance=\"$router\",name=\"cake-qos-ingress.service\",state=\"active\"}",
          "legendFormat": "CAKE Ingress",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "color": "#ee5396", "index": 0, "text": "DOWN" },
                "1": { "color": "#42be65", "index": 1, "text": "UP" }
              },
              "type": "value"
            }
          ]
        }
      },
      "options": { "orientation": "horizontal", "textMode": "name" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "WAN Throughput (enp101s0)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"$router\",device=\"enp101s0\"}[$__rate_interval]) * 8",
          "legendFormat": "Download",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"$router\",device=\"enp101s0\"}[$__rate_interval]) * -8",
          "legendFormat": "Upload",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "axisPlacement": "right",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Download" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#42be65", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Upload" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#08bdba", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LAN Throughput (enp100s0)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"$router\",device=\"enp100s0\"}[$__rate_interval]) * 8",
          "legendFormat": "Download",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"$router\",device=\"enp100s0\"}[$__rate_interval]) * -8",
          "legendFormat": "Upload",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "axisPlacement": "right",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Download" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#42be65", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Upload" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#08bdba", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "DNS Server Stats (dnsmasq)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 101,
      "type": "bargauge",
      "title": "Top 10 Requested Domains (Last 1h)",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (domain) (count_over_time({unit=\"dnsmasq.service\", host=\"saguaro\"} | regexp \"query\\\\[(?P<type>.*)\\\\] (?P<domain>.*) from\" [$__interval]))",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "limit": 10
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "id": 103,
      "type": "bargauge",
      "title": "Top 10 Clients (Last 1h)",
      "datasource": "Loki",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (client) (count_over_time({unit=\"dnsmasq.service\", host=\"saguaro\"} | regexp \"from (?P<client>[0-9.]+)\" [$__interval]))",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "limit": 10
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "id": 102,
      "type": "timeseries",
      "title": "DNS Query Volume by Type",
      "datasource": "Loki",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (type) (count_over_time({unit=\"dnsmasq.service\", host=\"saguaro\"} | regexp \"query\\\\[(?P<type>.*)\\\\] (?P<domain>.*) from\" [$__interval]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "qps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Bufferbloat & QoS (CAKE Effectiveness)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "CAKE Packets Dropped (Lower is Better)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(node_qdisc_drops_total{instance=\"$router\"}[$__rate_interval])",
          "legendFormat": "{{device}} ({{kind}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "CAKE Backlog (Queue Pressure)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "node_qdisc_backlog{instance=\"$router\"}",
          "legendFormat": "{{device}} bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decbytes", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Network Security (nftables)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 }
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "Firewall Packet Throughput by Chain",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "sum by (table, chain) (rate(node_nftables_chain_packets_total{instance=\"$router\"}[$__rate_interval]))",
          "legendFormat": "{{table}}:{{chain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Interface Reliability",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Interface Errors & Drops",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{instance=\"$router\"}[$__rate_interval])",
          "legendFormat": "{{device}} RX Error",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{instance=\"$router\"}[$__rate_interval])",
          "legendFormat": "{{device}} TX Error",
          "refId": "B"
        },
        {
          "expr": "rate(node_network_receive_drop_total{instance=\"$router\"}[$__rate_interval])",
          "legendFormat": "{{device}} RX Drop",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps", "custom": { "showPoints": "always" } }
      }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Router Logs & Health Checks",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 1 }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Critical Router Logs",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "{host=\"saguaro\", unit=~\"router-health-check|wan-watchdog|dnsmasq|nextdns|nftables|cake-qos-.*\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "WireGuard Exit Nodes",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 54, "w": 24, "h": 1 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Peer Throughput",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 55, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(wg_peer_transfer_rx_bytes{instance=~\"$exit_node\"}[$__rate_interval]) * 8",
          "legendFormat": "{{instance}} RX",
          "refId": "A"
        },
        {
          "expr": "rate(wg_peer_transfer_tx_bytes{instance=~\"$exit_node\"}[$__rate_interval]) * 8",
          "legendFormat": "{{instance}} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Last Handshake Age",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 55, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "time() - wg_peer_last_handshake_seconds{instance=~\"$exit_node\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#42be65", "value": null },
              { "color": "#ff7eb6", "value": 180 },
              { "color": "#ee5396", "value": 600 }
            ]
          }
        }
      }
    }
  ]
}
